# ============================================
# APPLICATION SETTINGS
# ============================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ============================================
# AWS S3 CONFIGURATION
# REQUIRED: Set these values before running
# ============================================
# Get these from AWS IAM console
# 1. Go to: https://console.aws.amazon.com/iam/
# 2. Create a user with S3 access
# 3. Generate access keys
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# AWS region where your S3 bucket is located
# Common regions: ap-southeast-1, us-east-1, eu-west-1
AWS_REGION=ap-southeast-1

# S3 bucket name for storing documents
# Create bucket at: https://s3.console.aws.amazon.com/
AWS_S3_BUCKET=study-ai-documents-bucket

# ============================================
# OPENAI CONFIGURATION
# REQUIRED: Set this before running
# ============================================
# Get your API key from: https://platform.openai.com/account/api-keys
# It should start with 'sk-'
OPENAI_API_KEY=sk-your_openai_api_key_here

# Model to use for quiz generation
# Options: gpt-4, gpt-3.5-turbo, gpt-4-turbo-preview
QUIZ_GENERATION_MODEL=gpt-4

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
# Maximum file size in bytes (50MB = 52428800 bytes)
MAX_FILE_SIZE=52428800

# Allowed file types (must be Python list format)
ALLOWED_FILE_TYPES=["pdf", "docx"]

# ============================================
# QUIZ SETTINGS
# ============================================
# Default number of questions to generate
DEFAULT_NUM_QUESTIONS=10

# Maximum allowed questions per quiz
MAX_NUM_QUESTIONS=50
